// prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Appointment {
  id                    Int          @id @default(autoincrement())
  nombre                String
  telefono              String
  tipo_consulta         TipoConsulta
  fecha                 String       // Stored as "YYYY-MM-DD"
  hora                  String       // Stored as "HH:MM"
  duracion              Int          @default(60) // Minutes
  estado                Estado       @default(pendiente)
  acepta_notificaciones Boolean      @default(false)
  push_subscription     String?      @db.Text // JSON string of PushSubscription
  created_at            DateTime     @default(now())
  updated_at            DateTime     @updatedAt

  @@map("appointments")
}

enum TipoConsulta {
  odontologica
  psicologica
}

enum Estado {
  pendiente
  aceptada
  rechazada
}
