# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=lumiplus
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=lumiplus_db

# ─── Backend ──────────────────────────────────────────────
DATABASE_URL=postgresql://lumiplus:change_this_strong_password@postgres:5432/lumiplus_db
PORT=3000
JWT_SECRET=change_this_to_a_random_64_char_string
FRONTEND_URL=http://localhost
NODE_ENV=production

# ─── Frontend (Vite build args) ───────────────────────────
# For local Docker: use http://localhost:3000
# For Render:       use https://your-backend.onrender.com
VITE_API_URL=http://localhost:3000
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key_here
