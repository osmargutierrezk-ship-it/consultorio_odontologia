# ──────────────────────────────────────────────
# .env.example — Copia este archivo a .env
# y rellena los valores antes de iniciar.
# NO subas .env a control de versiones (git).
# ──────────────────────────────────────────────

# ── Desarrollo local (docker-compose) ─────────
POSTGRES_USER=dental_user
POSTGRES_PASSWORD=dental_pass
POSTGRES_DB=dental_db

# ── URL de conexión completa ───────────────────
# Render la inyecta automáticamente como DATABASE_URL
# En local usa este formato:
DATABASE_URL=postgres://dental_user:dental_pass@localhost:5432/dental_db

# ── App ────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── CORS (opcional, deja vacío para permitir todos) ─
ALLOWED_ORIGIN=http://localhost:3000
