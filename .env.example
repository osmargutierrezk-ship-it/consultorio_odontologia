# ─── External PostgreSQL (Render Database) ──────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# ─── Backend ────────────────────────────────────────────────
PORT=3000
JWT_SECRET=change_this_to_a_random_64_char_string
# Comma-separated origins allowed by CORS (for production set your Render URL)
FRONTEND_URL=https://your-app.onrender.com
NODE_ENV=production

# ─── Frontend build args (optional) ─────────────────────────
# Leave empty to use same-origin requests in unified container
VITE_API_URL=
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key_here
