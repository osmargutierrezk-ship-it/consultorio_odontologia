# LumiPlus — Variables de Entorno
# Copia este archivo como .env para desarrollo local

# Base de datos PostgreSQL (Render provee esta variable automáticamente)
DATABASE_URL="postgresql://usuario:password@localhost:5432/lumiplus"

# Puerto del servidor (Render lo asigna automáticamente)
PORT=3000

# Entorno
NODE_ENV=production

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Genera estas claves corriendo: npx web-push generate-vapid-keys
# Instrucciones en README.md

VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:admin@lumiplus.com
